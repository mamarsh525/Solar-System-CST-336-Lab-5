<!DOCTYPE html>
<html lang="en">

<head>
    <%- include("partials/head.ejs") %>
</head>

<body>
    <h1 class="bg-info text-white p-3 m-0"> The Solar System </h1>
    <%- include("partials/nav.ejs") %>
   

    <div class="container-fluid row">

        <div class="card p-4 col ">
            <h2> <%=planet %> </h2>
            
            <span><%= planetInfo.description %></span><br>
            <span>Distance: <%= planetInfo.distanceFromSun %></span><br>
            <span>Year Length: <%= planetInfo.yearLength %></span><br>
            <span>Radius: <%= planetInfo.radius %></span><br>
            <span>One Earth Day: <%= planetInfo.oneEarthDay %></span><br>
            <span>Moons: <%= planetInfo.moons %></span><br>
        </div>

        <div class="card p-4 col">
            <img src="<%=planetInfo.image %>">
        </div>

    </div>

</body>
<%- include("partials/footer.ejs") %>

</html>